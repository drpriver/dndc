::css
  * {
    box-sizing: border-box;
  }
  body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100vh;
    padding: 0;
    margin: 0;
  }
  html {
    padding: 0;
    margin: 0;
  }
  #left, #right {
    height: 100%;
    overflow-y: scroll;
  }
  #right {
    padding-left: 16px;
  }
  /*endcss*/
::div #id(left)
  ::imglinks
    level1.png
    width = 777
    height = 800
    viewBox = 0 0 1455 1497
    ::js
      let imglinks = node.parent;
      let coord_nodes = ctx.select_nodes({classes:['level1'], attributes:['coord']});
      for(let c of coord_nodes){
        let lead = c.header.split('.')[0];
        let position = c.attributes.get('coord');
        imglinks.add_child(`${lead} = #${c.id} @${position}`);
      }
      //endjs
  ::imglinks
    level2.png
    width = 774
    height = 800
    viewBox = 0 0 1236 1277
    ::js
      // this is an example of how to script the imglinks
      let imglinks = node.parent;
      let coord_nodes = ctx.select_nodes({classes:['level2'], attributes:['coord']});
      for(let c of coord_nodes){
        let lead = c.header.split('.')[0];
        let position = c.attributes.get('coord');
        imglinks.add_child(`${lead} = #${c.id} @${position}`);
      }
      //endjs

