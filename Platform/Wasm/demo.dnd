    ::css
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; }
      table { text-align: center; }
      table, table * {
        border: 1px solid black;
        border-collapse: collapse;
      }
      td { padding: 4px 12px; }
      img { width: 100%;}
      body { max-width: 60em; margin: auto; padding: 0px 48px; }
      /*endcss*/

    </textarea>
    <div id="checkboxes">
      <input type="checkbox" id="autoapply" name="autoapply" value="autoapply" checked>
      <label for="autoapply">Auto-Apply Changes</label>
      <button id="apply-button">Apply</button>
      <button id="format-button">Format</button>
      <button id="save-button">Save</button>
      <button id="export-button">Export as HTML</button>
    </div>
    <div id="log"></div>
::script .wasm
  //endjs
::js
  ctx.add_dependency('Objs/dndc.wasm');
  let inline = ctx.select_nodes({type:NodeType.SCRIPTS, classes:['wasm']})[0];
  let b64 = FileSystem.load_file_as_base64('Objs/dndc.wasm');
  inline.add_child(`const prog64 = "${b64}";`);
  //endjs

::css
  * {
    box-sizing: border-box;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; }
  body {
    margin: 0;
    width: 100%;
    height: 100vh;
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 2em 6em;
    height: 100%;
    width: 100%;
  }
  iframe {
    grid-column: 1;
    grid-row: 1 / 4;
    height: 100%;
    width: 100%;
    opacity: none;
  }
  .right {
    grid-column: 2;
    grid-row: 1;
  }
  textarea {
    font-family: Menlo, Mono;
    resize: none;
  }
  #log {
    grid-column: 2;
    grid-row: 3;
    border: 1px solid gray;
  }
  #checkboxes{
    grid-column: 2;
    grid-row: 2;
  }
  #log * {
    padding: 3px;
  }
  /*endcss*/
::script
  let AUTOAPPLY = true;
  document.addEventListener('DOMContentLoaded', function(){
      let autoapply = document.getElementById('autoapply');
      autoapply.addEventListener('input', function(){
        AUTOAPPLY = autoapply.checked;
      });
      let apply_button = document.getElementById('apply-button');
      apply_button.addEventListener('click', function(e){
        apply_changes();
        e.stopPropagation();
        e.preventDefault();
      });
      let format_button = document.getElementById('format-button');
      format_button.addEventListener('click', function(e){
        e.stopPropagation();
        e.preventDefault();
        const ta = document.getElementsByTagName('textarea')[0];
        ta.value = format_dnd(ta.value);
      });
      let save_button = document.getElementById('save-button');
      save_button.addEventListener('click', function(e){
        e.stopPropagation();
        e.preventDefault();
        const ta = document.getElementsByTagName('textarea')[0];
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([ta.value], {type:'text/plain'}));
        a.download = "demo.dnd";
        a.click();
      });
      let export_button = document.getElementById('export-button');
      export_button.addEventListener('click', function(e){
        e.stopPropagation();
        e.preventDefault();
        const ta = document.getElementsByTagName('textarea')[0];
        const s = dndc_make_html(ta.value);
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([s], {type:'text/html'}));
        a.download = "demo.html";
        a.click();
      });
  });
  var wasm;
  var wasm_instance;
  var decoder = new TextDecoder();
  var encoder = new TextEncoder();
  var memory;
  function clear_log(){
      const log = document.getElementById('log');
      log.innerHTML = '';
  }
  function marshall_string(string){
      let encoded = encoder.encode(string)
      let p = wasm_instance.exports.malloc(encoded.length+5);
      let lengthp = memory.subarray(p, p+4);
      lengthp[0] = (encoded.length >> 0) & 255;
      lengthp[1] = (encoded.length >> 8) & 255;
      lengthp[2] = (encoded.length >> 16) & 255;
      lengthp[3] = (encoded.length >> 24) & 255;
      let sub = memory.subarray(p+4, p+4+encoded.length);
      memory[p+4+encoded.length] = 0;
      sub.set(encoded);
      return p;
  }
  function wasm_string_to_js(pstring){
      let sub = memory.subarray(pstring, pstring+4);
      let length = sub[0]| (sub[1]<<8) | (sub[2]<<16) | (sub[3]<<24);
      let textmem = memory.subarray(pstring+4, pstring+4+length);
      let text = decoder.decode(textmem);
      return text;
  }
  var imports = {
      env: {
          logi32: function(i) {
              console.log(i);
          },
          log_string: function(p, len){
              let sub = memory.subarray(p, p+len);
              const log = document.getElementById('log');
              const pp = document.createElement('pre');
              pp.innerHTML = decoder.decode(sub);
              log.appendChild(pp);
          },
          dom_write: function(p, len){
              let sub = memory.subarray(p, p+len);
              document.body.innerHTML += decoder.decode(sub);
          },
          input: function(){
              const text = prompt("input:");
              return marshall_string(text);
          },
          abort: function(){
            throw new WebAssembly.RuntimeError('abort');
          }
      }
  };
  const wasm_buffer = Uint8Array.from(atob(prog64), c => c.charCodeAt(0)).buffer;
  WebAssembly.compile(wasm_buffer).then(x => {
      wasm = x;
      WebAssembly.instantiate(wasm, imports).then(x => {;
          wasm_instance = x;
          wasm_instance.exports.memory.grow(1024);
          memory = new Uint8Array(wasm_instance.exports.memory.buffer);
          // let version = wasm_string_to_js(wasm_instance.exports.VERSION);
          // console.log('dndc VERSION:', version);
          apply_changes();
      });
  });

  function dndc_make_html(string){
      if(!string.length)
        return "";
      //const before = performance.now();
      wasm_instance.exports.reset_memory();
      const marshalled = marshall_string(string);
      let result = wasm_instance.exports.make_html(marshalled);
      if(result){
          const jsresult = wasm_string_to_js(result);
          //const after = performance.now();
          //console.log(`after-before: ${after-before}ms`);
          return jsresult;
      }
      throw new Error("Some error in htmlgen");
  }
  function format_dnd(string){
    if(!string.length)
      return "";
    wasm_instance.exports.reset_memory();
    const marshalled = marshall_string(string);
    let result = wasm_instance.exports.format_dnd(marshalled);
    if(result){
      const jsresult = wasm_string_to_js(result);
      return jsresult;
    }
    throw new Error("Some error in htmlgen");
  }

  function set_dnd(string){
      const html = dndc_make_html(string);
      const iframe = document.getElementsByTagName('iframe')[0];
      iframe.srcdoc = html;
  }
  let apply_changes;
  document.addEventListener('DOMContentLoaded', function(){
    const ta = document.getElementsByTagName('textarea')[0];
    apply_changes = function(){
        clear_log();
        set_dnd(ta.value);
    };
    ta.addEventListener('input', function(){
      if(AUTOAPPLY){
        apply_changes();
      }
    });
    ta.addEventListener('keydown', function(e){
      if(e.key != 'Tab')
        return;
      e.preventDefault();
      let start = ta.selectionStart;
      let end = ta.selectionEnd;
      ta.value = ta.value.substring(0, start) + "  " + ta.value.substring(end);
      // restore cursor position
      ta.selectionStart = ta.selectionEnd = start+2;
    });
  });
  //endjs
